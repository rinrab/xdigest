CC = cl.exe
LINK = link.exe
LIB = lib.exe
CFLAGS = /c /O2 /W4 /Ixdigest/include /DNO_ASM 

all: libxdigest.lib

OBJEXT = .obj
include Makefile.inc

.c.obj:
  $(CC) /nologo $(CFLAGS) /Fo$*.obj $*.c

libxdigest.lib: $(c_objects)
  $(LIB) /nologo /out:libxdigest.lib $(c_objects)

test_xdigest.exe: libxdigest.lib tests/test_xdigest.obj tests/sha_test.obj
	$(LINK) /nologo $<

check: test_xdigest.exe
	test_xdigest.exe

clean:
  del /S *.obj *.lib

rebuild: clean all

