#!/bin/sh

set -e

linkage=shared
for OPTION; do
    case "${OPTION}" in
    --vcpkg-prefix=*)
        vcpkg_prefix="${OPTION#--vcpkg-prefix=}"
        ;;
    --enable-static)
        linkage=static
        ;;
    esac
done

cat > Makefile.conf <<END_MAKEFILE ;

BUILD_OPTIONS = \
    "prefix=$vcpkg_prefix"

all:
	\$(MAKE) all \$(BUILD_OPTIONS)

install:
	\$(MAKE) install \$(BUILD_OPTIONS)

END_MAKEFILE
