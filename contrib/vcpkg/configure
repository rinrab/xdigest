#!/bin/sh

set -e

linkage=shared
prefix=
for OPTION; do
    case "${OPTION}" in
    --prefix=*)
        prefix="${OPTION#--prefix=}"
        ;;
    --enable-static)
        linkage=static
        ;;
    esac
done

cat > Makefile.conf <<END_MAKEFILE ;

BUILD_OPTIONS = \
    "prefix=$prefix"

all:
	\$(MAKE) all \$(BUILD_OPTIONS)

install:
	\$(MAKE) install \$(BUILD_OPTIONS)

END_MAKEFILE
